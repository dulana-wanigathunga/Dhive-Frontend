# Backend API base URL — MUST end with /api and NO trailing slash.
# Local:  http://localhost:5000/api
# Prod:   https://your-backend.up.railway.app/api
REACT_APP_API_URL=http://localhost:5000/api

# Google OAuth client ID (same one used by the frontend app is fine)
REACT_APP_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# Firebase (image uploads only)
REACT_APP_FIREBASE_APIKEY=your_firebase_web_api_key
